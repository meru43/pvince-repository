<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>회원 관리</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/css/admin-users.css" />
</head>

<div class="admin-password-modal" id="admin-password-modal" hidden>
    <div class="admin-password-modal-backdrop" id="admin-password-modal-backdrop"></div>

    <div class="admin-password-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="admin-password-modal-title">
        <h3 class="admin-password-modal-title" id="admin-password-modal-title">임시 비밀번호</h3>

        <p class="admin-password-modal-desc">
            아래 임시 비밀번호를 회원에게 전달한 뒤, 로그인 후 마이페이지에서 새 비밀번호로 변경하도록 안내해주세요.
        </p>

        <div class="admin-password-modal-code-wrap">
            <code class="admin-password-modal-code" id="admin-password-modal-code">SJ000000</code>
        </div>

        <div class="admin-password-modal-actions">
            <button type="button" class="btn btn-outline" id="admin-password-copy-btn">복사</button>
            <button type="button" class="btn btn-primary" id="admin-password-close-btn">확인</button>
        </div>

        <p class="admin-password-modal-message" id="admin-password-modal-message"></p>
    </div>
</div>

<body>
    <%- include('partials/header') %>

        <main class="container page">
            <section class="page-title-wrap">
                <h2 class="page-title">회원 관리</h2>
                <p class="page-desc">관리자는 일반회원과 셀러회원을 구분해 지정할 수 있습니다.</p>
            </section>

            <div class="admin-users-search">
                <input type="text" id="admin-user-search" placeholder="아이디, 닉네임, 이메일, 이름, 전화번호 검색" />
                <button type="button" class="btn btn-outline" id="admin-user-search-btn">검색</button>
            </div>

            <section class="admin-users-box">
                <div class="admin-user-row admin-users-head">
                    <span class="col-profile">프로필</span>
                    <span class="col-username">아이디</span>
                    <span class="col-nickname">닉네임</span>
                    <span class="col-email">이메일</span>
                    <span class="col-name">이름</span>
                    <span class="col-phone">전화번호</span>
                    <span class="col-user-status">회원 상태</span>
                    <span class="col-role">현재 권한</span>
                    <span class="col-action">권한 변경</span>
                </div>

                <div id="admin-users-list">
                    <p class="empty-message">회원 목록을 불러오는 중입니다.</p>
                </div>
            </section>
        </main>

        <script src="/js/common.js"></script>
        <script src="/js/admin-users.js"></script>
</body>

</html>