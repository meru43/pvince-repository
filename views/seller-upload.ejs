<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>상품 등록</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/css/seller-upload.css" />
</head>

<body>
    <%- include('partials/header') %>

        <main class="container page">
            <section class="page-title-wrap">
                <h2 class="page-title">상품 등록</h2>
                <p class="page-desc">셀러 또는 관리자만 상품을 등록할 수 있습니다.</p>
            </section>

            <section class="seller-upload-box">
                <form id="seller-upload-form" class="seller-upload-form">
                    <div class="form-group">
                        <label for="product-title">상품명</label>
                        <input type="text" id="product-title" placeholder="상품명을 입력하세요" />
                    </div>

                    <div class="form-group">
                        <label for="product-price">가격</label>
                        <input type="number" id="product-price" placeholder="가격을 입력하세요" />
                    </div>

                    <div class="form-group">
                        <label for="product-file-name">파일명</label>
                        <input type="text" id="product-file-name" placeholder="예: template01.zip" />
                    </div>

                    <div class="form-group">
                        <label for="product-file-path">파일 경로</label>
                        <input type="text" id="product-file-path" placeholder="예: downloads/template01.zip" />
                    </div>

                    <div class="form-group">
                        <label for="product-description">설명</label>
                        <textarea id="product-description" placeholder="상품 설명을 입력하세요"></textarea>
                    </div>

                    <p class="seller-upload-error" id="seller-upload-error"></p>

                    <div class="seller-upload-actions">
                        <button type="submit" class="btn btn-primary">상품 등록</button>
                    </div>
                </form>
            </section>
        </main>

        <script src="/js/common.js"></script>
        <script src="/js/seller-upload.js"></script>
</body>

</html>